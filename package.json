{
  "name": "kitty",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@12.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "24.12.0",
    "npm": "12.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace=@kitty/app",
    "build": "npm run build --workspace=@kitty/app",
    "preview": "npm run preview --workspace=@kitty/app",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspace=@kitty/app",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@kinky-vibes/ui": "0.1.0",
    "tone": "15.5.27",
    "vue": "3.5.39"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.0",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.11",
    "axe-core": "4.12.1",
    "eslint": "10.7.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "16.5.0",
    "happy-dom": "20.10.6",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.7"
  }
}
